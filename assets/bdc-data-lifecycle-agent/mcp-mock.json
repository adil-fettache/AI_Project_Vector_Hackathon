              "spaceId": {"type": "string", "description": "Space identifier"}
            },
            "required": ["spaceId"]
          },
          "mock_response": {
            "spaceId": "SALES_SPACE",
            "spaceName": "Sales Analytics",
            "status": "ACTIVE",
            "diskStorageQuota": 1073741824,
            "inMemoryStorageQuota": 536870912
          }
        },
        "list_artifacts": {
          "description": "List artifacts in a Datasphere space",
          "input_schema": {
            "type": "object",
            "properties": {
              "spaceId": {"type": "string", "description": "Space identifier"},
              "artifactType": {"type": "string", "description": "Type: view, flow, model"},
              "top": {"type": "integer", "description": "Max results"}
            },
            "required": ["spaceId"]
          },
          "mock_response": {
            "results": [
              {"artifactId": "SalesView", "artifactType": "SQLView", "status": "DEPLOYED", "spaceId": "SALES_SPACE"},
              {"artifactId": "RevenueModel", "artifactType": "AnalyticModel", "status": "DEPLOYED", "spaceId": "SALES_SPACE"}
            ]
          }
        },
        "get_artifact": {
          "description": "Get details of a specific artifact",
          "input_schema": {
            "type": "object",
