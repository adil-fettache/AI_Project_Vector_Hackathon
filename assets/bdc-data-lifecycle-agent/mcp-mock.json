              {"spaceId": "FINANCE_SPACE", "spaceName": "Finance Data", "status": "ACTIVE"},
              {"spaceId": "HR_SPACE", "spaceName": "HR Workspace", "status": "INACTIVE"}
            ]
          }
        },
        "get_space": {
          "description": "Get details of a specific Datasphere space",
          "input_schema": {
            "type": "object",
