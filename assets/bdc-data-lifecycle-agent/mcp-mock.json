{
  "servers": {
    "catalog-datasphere": {
      "mcp_server_name": "catalog-datasphere-mcp-server",
      "description": "MCP server for SAP Datasphere Catalog — list spaces, artifacts, metadata",
      "tools": {
        "list_spaces": {
          "description": "List all Datasphere spaces",
          "input_schema": {
            "type": "object",
            "properties": {
              "top": {"type": "integer", "description": "Maximum number of spaces to return"}
