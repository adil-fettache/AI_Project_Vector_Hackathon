            "status": "ACTIVATION_INITIATED",
            "taskId": "task_001",
            "productName": "SalesOrder",
            "targetSpace": "SALES_SPACE",
            "message": "Activation task started successfully"
          }
        },
        "write_metadata": {
          "description": "Write governance metadata for a data product",
          "input_schema": {
            "type": "object",
            "properties": {
              "productName": {"type": "string", "description": "Data product name"},
              "description": {"type": "string", "description": "Description"},
              "owner": {"type": "string", "description": "Owner"},
              "tags": {"type": "string", "description": "Tags as JSON list"}
            },
            "required": ["productName"]
          },
          "mock_response": {
            "status": "METADATA_WRITTEN",
            "productName": "SalesOrder",
            "updatedFields": ["description", "owner", "tags"]
          }
        },
        "list_lineage": {
          "description": "List lineage information for a data product",
          "input_schema": {
            "type": "object",
            "properties": {
              "productName": {"type": "string", "description": "Data product name"}
            },
            "required": ["productName"]
          },
          "mock_response": {
            "productName": "SalesOrder",
            "sources": ["SAP S/4HANA SALES_ORDER"],
            "targets": ["SAC SalesStory"],
            "transformations": ["SalesView SQL transformation"]
          }
        }
      }
