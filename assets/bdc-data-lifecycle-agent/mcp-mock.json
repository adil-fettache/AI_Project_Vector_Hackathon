          "mock_response": {
            "productName": "SalesOrder",
            "description": "Sales order data product",
            "owner": "Finance Team",
            "tags": ["sales", "orders", "finance"],
            "lineage": "SAP S/4HANA -> Datasphere -> SAC"
          }
        },
        "list_data_products": {
          "description": "List SAP-managed data products in the BDC catalog",
          "input_schema": {
            "type": "object",
            "properties": {
              "top": {"type": "integer", "description": "Max results"}
            },
            "required": []
          },
          "mock_response": {
            "results": [
              {"name": "SalesOrder", "type": "SAP-managed", "status": "ACTIVE", "targetSpace": "SALES_SPACE"},
              {"name": "PurchaseOrder", "type": "SAP-managed", "status": "INACTIVE", "targetSpace": "FINANCE_SPACE"},
              {"name": "FinancialStatement", "type": "SAP-managed", "status": "ACTIVE", "targetSpace": "FINANCE_SPACE"}
            ]
          }
        },
        "search_data_products": {
          "description": "Search SAP-managed data products by name, type, or application",
          "input_schema": {
            "type": "object",
            "properties": {
              "query": {"type": "string", "description": "Search term"},
