{
  "openapi": "3.0.0",
  "info": {
    "title": "Data Profiling",
    "version": "1.0.0",
    "description": "SAP Data Quality Management Data Profiling API for profiling data assets, running quality checks and enforcing data quality rules"
  },
  "paths": {
    "/profiling/jobs": {
      "post": {
        "operationId": "createProfilingJob",
        "summary": "Start a data profiling job",
        "description": "Initiates a profiling job to analyze data quality dimensions (completeness, uniqueness, validity, consistency, accuracy) for a data asset",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["assetId"],
                "properties": {
                  "assetId": {"type": "string", "description": "ID of the data asset to profile"},
                  "spaceId": {"type": "string"},
                  "dimensions": {"type": "array", "items": {"type": "string", "enum": ["COMPLETENESS", "UNIQUENESS", "VALIDITY", "CONSISTENCY", "ACCURACY", "TIMELINESS"]}},
                  "sampleSize": {"type": "integer"},
                  "rules": {"type": "array", "items": {"$ref": "#/components/schemas/QualityRule"}}
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Profiling job created",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfilingJob"}}}
          }
        }
      },
      "get": {
        "operationId": "listProfilingJobs",
        "summary": "List profiling jobs",
        "description": "Returns a list of all data profiling jobs with their status",
        "parameters": [
          {"name": "assetId", "in": "query", "schema": {"type": "string"}},
          {"name": "status", "in": "query", "schema": {"type": "string", "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED"]}}
        ],
        "responses": {
          "200": {
            "description": "Profiling jobs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {"value": {"type": "array", "items": {"$ref": "#/components/schemas/ProfilingJob"}}}
                }
              }
            }
          }
        }
      }
    },
    "/profiling/jobs/{jobId}": {
      "get": {
        "operationId": "getProfilingJob",
        "summary": "Get profiling job status and results",
        "parameters": [{"name": "jobId", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {
            "description": "Profiling job",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfilingJob"}}}
          }
        }
      }
    },
    "/profiling/jobs/{jobId}/results": {
      "get": {
        "operationId": "getProfilingResults",
        "summary": "Get detailed profiling results",
        "description": "Returns detailed quality metrics and rule evaluation results for a completed profiling job",
        "parameters": [{"name": "jobId", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {
            "description": "Profiling results",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ProfilingResults"}}}
          }
        }
      }
    },
    "/quality/rules": {
      "get": {
        "operationId": "listQualityRules",
        "summary": "List quality rules",
        "description": "Returns all defined data quality rules",
        "parameters": [
          {"name": "assetId", "in": "query", "schema": {"type": "string"}},
          {"name": "dimension", "in": "query", "schema": {"type": "string"}}
        ],
        "responses": {
          "200": {
            "description": "Quality rules",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {"value": {"type": "array", "items": {"$ref": "#/components/schemas/QualityRule"}}}
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createQualityRule",
        "summary": "Create a data quality rule",
        "description": "Defines a new data quality rule for enforcement during profiling and deployment gates",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QualityRule"}}}
        },
        "responses": {
          "201": {
            "description": "Created rule",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QualityRule"}}}
          }
        }
      }
    },
    "/quality/rules/{ruleId}": {
      "get": {
        "operationId": "getQualityRule",
        "summary": "Get a quality rule by ID",
        "parameters": [{"name": "ruleId", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {
            "description": "Quality rule",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QualityRule"}}}
          }
        }
      },
      "delete": {
        "operationId": "deleteQualityRule",
        "summary": "Delete a quality rule",
        "parameters": [{"name": "ruleId", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"204": {"description": "Rule deleted"}}
      }
    },
    "/quality/scores/{assetId}": {
      "get": {
        "operationId": "getQualityScore",
        "summary": "Get current quality score for an asset",
        "description": "Returns the latest computed quality score and dimension breakdown for a data asset",
        "parameters": [{"name": "assetId", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {
          "200": {
            "description": "Quality score",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/QualityScore"}}}
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QualityRule": {
        "type": "object",
        "properties": {
          "ruleId": {"type": "string"},
          "name": {"type": "string"},
          "description": {"type": "string"},
          "assetId": {"type": "string"},
          "dimension": {"type": "string", "enum": ["COMPLETENESS", "UNIQUENESS", "VALIDITY", "CONSISTENCY", "ACCURACY", "TIMELINESS"]},
          "severity": {"type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]},
          "condition": {"type": "string"},
          "column": {"type": "string"},
          "threshold": {"type": "number"},
          "enabled": {"type": "boolean"}
        }
      },
      "ProfilingJob": {
        "type": "object",
        "properties": {
          "jobId": {"type": "string"},
          "assetId": {"type": "string"},
          "status": {"type": "string", "enum": ["PENDING", "RUNNING", "COMPLETED", "FAILED"]},
          "startedAt": {"type": "string", "format": "date-time"},
          "completedAt": {"type": "string", "format": "date-time"},
          "rowsScanned": {"type": "integer"},
          "overallScore": {"type": "number"},
          "passedRules": {"type": "integer"},
          "failedRules": {"type": "integer"},
          "criticalViolations": {"type": "integer"}
        }
      },
      "ProfilingResults": {
        "type": "object",
        "properties": {
          "jobId": {"type": "string"},
          "assetId": {"type": "string"},
          "overallScore": {"type": "number"},
          "dimensions": {"type": "object"},
          "ruleResults": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ruleId": {"type": "string"},
                "ruleName": {"type": "string"},
                "severity": {"type": "string"},
                "passed": {"type": "boolean"},
                "failureRate": {"type": "number"},
                "failedRows": {"type": "integer"},
                "details": {"type": "string"}
              }
            }
          }
        }
      },
      "QualityScore": {
        "type": "object",
        "properties": {
          "assetId": {"type": "string"},
          "overallScore": {"type": "number"},
          "completenessScore": {"type": "number"},
          "uniquenessScore": {"type": "number"},
          "validityScore": {"type": "number"},
          "consistencyScore": {"type": "number"},
          "computedAt": {"type": "string", "format": "date-time"},
          "criticalViolations": {"type": "integer"},
          "gatePassed": {"type": "boolean"}
        }
      }
    }
  }
}
