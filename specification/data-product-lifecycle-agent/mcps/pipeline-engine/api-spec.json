{
  "swagger": "2.0",
  "info": {
    "version": "1.2",
    "title": "Pipeline Engine (Cloud Edition)",
    "description": "The Pipeline Engine (vFlow) API provides access to the repository and the runtime of data processing pipelines (graphs). It facilitates the automation of operational tasks such as creating, starting and monitoring pipelines using external tooling."
  },
  "x-sap-shortText": "Access to the runtime environment of data processing pipelines for complex data driven scenarios.",
  "externalDocs": {
    "description": "Modeling Guide for SAP Data Intelligence Cloud",
    "url": "https://help.sap.com/viewer/1c1341f6911f4da5a35b191b40b426c8/Cloud/en-US/3659021a9c1c434cb146e9f99fcaf291.html"
  },
  "host": "hostname",
  "basePath": "/pipeline-modeler/service",
  "tags": [
    {
      "name": "Repository",
      "description": "Access to the repository of vFlow artifacts."
    },
    {
      "name": "Runtime",
      "description": "Access to the runtime of vFlow."
    },
    {
      "name": "System",
      "description": "Access to the vFlow system information."
    }
  ],
  "schemes": [
    "https"
  ],
  "securityDefinitions": {
    "UserSecurity": {
      "type": "basic"
    }
  },
  "security": [
    {
      "UserSecurity": []
    }
  ],
  "x-servers": [
    {
      "url": "https://vsystem.ingress.{Cloud Instance}.{Landscape}.k8s-hana.ondemand.com/app/pipeline-modeler/service",
      "description": "Pipeline Engine endpoint in an SAP Data Intelligence Cloud instance.",
      "templates": {
        "Cloud Instance": {
          "description": "The name of the SAP Data Intelligence Cloud instance."
        },
        "Landscape": {
          "description": "The landscape where the SAP Data Intelligence Cloud instance is running.",
          "enum": [
            "dhaas-live.shoot.live",
            "di-us-east.shoot.live",
            "di-xas.shoot.live",
            "di-xat.shoot.live",
            "di-xmj.shoot.live",
            "di-xm8.shoot.live"
          ]
        }
      }
    }
  ],
  "paths": {
    "/v1/version": {
      "get": {
        "tags": [
          "System"
        ],
        "description": "Get the version of the vFlow runtime.",
        "summary": "Get the runtime version",
        "operationId": "getVersion",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "The version of the vFlow runtime.",
            "schema": {
              "$ref": "#/definitions/Version"
            }
          }
        }
      }
    },
    "/v1/repository/graphs": {
      "get": {
        "tags": [
          "Repository"
        ],
        "description": "This operation can be used to list all graphs from the repository.",
        "summary": "List repository graphs",
        "operationId": "listGraphs",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "regex",
            "in": "query",
            "description": "Regular expression to be used for finding graphs.",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "List of graph entities.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/EntityInfo"
              }
            }
          }
        }
      }
    },
    "/v1/repository/graphs/{name}": {
      "get": {
        "tags": [
          "Repository"
        ],
        "description": "Find a graph in the repository given its name.",
        "summary": "Find a graph by name",
        "operationId": "getGraph",
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "description": "The name of the graph to return.",
            "required": true,
            "type": "string"
          },
          {
            "name": "subentity",
            "in": "query",
            "description": "The name of a subentity.",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "The graph description object.",
            "schema": {
              "$ref": "#/definitions/GraphDescription"
            }
          },
          "404": {
            "description": "The graph was not found."
          }
        }
      }
    },
    "/v1/runtime/graphs": {
      "get": {
        "tags": [
          "Runtime"
        ],
        "description": "Lists all graphs of the runtime, independent of their state and execution contexts.",
        "summary": "List runtime graphs",
        "operationId": "listExecutionGraphs",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "The list of graph execution objects.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/GraphExecution"
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Runtime"
        ],
        "description": "Start a specific graph given by a graph execution request.",
        "summary": "Start a graph",
        "operationId": "startExecutionGraph",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json",
          "text/plain; charset=utf-8"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "A graph execution request.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/GraphExecutionRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Updated graph execution object containing a new handle.",
            "schema": {
              "$ref": "#/definitions/GraphExecution"
            }
          },
          "400": {
            "description": "The graph cannot be started.",
            "schema": {
              "$ref": "#/definitions/GraphCheckInfos"
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Runtime"
        ],
        "description": "Delete or stop all or selected graphs. The `handles` parameter can be used to restrict the operation to a subset of graphs to be stopped or deleted.",
        "summary": "Delete or stop multiple graphs",
        "operationId": "deleteAllExecutionGraphs",
        "parameters": [
          {
            "name": "stop",
            "in": "query",
            "description": "If set, only stop the graphs. If not set, delete the graphs.",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "handles",
            "in": "query",
            "description": "A comma-separated list of graph handles to restrict the operation.",
            "required": false,
            "type": "string"
          },
          {
            "name": "skipdead",
            "in": "query",
            "description": "If set, only delete the completed graphs, keeping the dead ones.",
            "required": false,
            "type": "boolean"
          },
          {
            "name": "includeSnapshot",
            "in": "query",
            "description": "If set, graphs with snapshot enabled are also deleted.",
            "required": false,
            "default": false,
            "type": "boolean"
          }
        ],
        "responses": {
          "202": {
            "description": "The delete or stop request was accepted.",
            "schema": {
              "type": "object",
              "properties": {
                "succeeded": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "skipped": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "failed": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/runtime/graphs/{handle}": {
      "parameters": [
        {
          "name": "handle",
          "in": "path",
          "description": "The handle of the graph.",
          "required": true,
          "type": "string"
        }
      ],
      "get": {
        "tags": [
          "Runtime"
        ],
        "description": "Get the execution details of a specific graph. This includes information such as the execution status, start time, container details and more.",
        "summary": "Get the execution status of a graph",
        "operationId": "getExecutionGraph",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "The graph execution object.",
            "schema": {
              "$ref": "#/definitions/GraphExecution"
            }
          },
          "404": {
            "description": "The graph was not found."
          }
        }
      },
      "delete": {
        "tags": [
          "Runtime"
        ],
        "description": "Delete or stop a specific graph given by the `handle` parameter.",
        "summary": "Delete or stop a graph",
        "operationId": "deleteExecutionGraph",
        "produces": [
          "text/plain"
        ],
        "parameters": [
          {
            "name": "stop",
            "in": "query",
            "description": "If set, only stop the graph. If not set, delete the graph.",
            "required": false,
            "type": "boolean",
            "allowEmptyValue": true
          },
          {
            "name": "force",
            "in": "query",
            "description": "Valid only in conjunction with the `stop` parameter. If set, force graph stopping, i.e., delete the graph pods.",
            "required": false,
            "type": "boolean",
            "allowEmptyValue": true
          }
        ],
        "responses": {
          "200": {
            "description": "The graph execution object.",
            "schema": {
              "$ref": "#/definitions/GraphExecution"
            }
          },
          "404": {
            "description": "The graph was not found."
          },
          "500": {
            "description": "The graph cannot be removed, because it is currently running."
          }
        }
      }
    },
    "/v1/runtime/restartgroups/{restartGroupID}": {
      "parameters": [
        {
          "name": "restartGroupID",
          "in": "path",
          "description": "The id of the restart group.",
          "required": true,
          "type": "string"
        }
      ],
      "post": {
        "tags": [
          "Runtime"
        ],
        "description": "A restart group can be paused or resumed using this operation.",
        "summary": "Pause or resume a restart group",
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "description": "Action of the restart group",
            "type": "string",
            "required": true,
            "enum": [
              "pause",
              "resume"
            ]
          }
        ],
        "consumes": [
          "application/json"
        ],
        "produces": [
          "text/plain; charset=utf-8"
        ],
        "responses": {
          "200": {
            "description": "Resume restart group successfully"
          },
          "202": {
            "description": "Pause restart group successfully"
          },
          "404": {
            "description": "The restart group not found."
          },
          "409": {
            "description": "The latest graph of the restart group is not in running status if action is pause Or is not dead/paused status if action is resume "
          },
          "500": {
            "description": "An internal server error occurred."
          }
        }
      },
      "delete": {
        "tags": [
          "Runtime"
        ],
        "description": "Use this operation to remove all graphs in restart group",
        "summary": "Remove graphs in restart group",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "text/plain; charset=utf-8",
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "The delete request was accepted.",
            "schema": {
              "type": "object",
              "description": "The result of deletion",
              "properties": {
                "succeeded": {
                  "type": "array",
                  "description": "Graph handles that are archived successfully",
                  "items": {
                    "type": "string"
                  }
                },
                "skipped": {
                  "type": "array",
                  "description": "Graph handles that are skipped to be archived",
                  "items": {
                    "type": "string"
                  }
                },
                "failed": {
                  "type": "array",
                  "description": "Graph handles that are archived unsuccessfully",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "404": {
            "description": "The restart group not found."
          },
          "500": {
            "description": "An internal server error occurred."
          }
        }
      }
    },
    "/v1/runtime/graphdescriptions/{handle}": {
      "parameters": [
        {
          "name": "handle",
          "in": "path",
          "description": "The handle of the graph.",
          "required": true,
          "type": "string"
        }
      ],
      "get": {
        "tags": [
          "Runtime"
        ],
        "description": "Get the graph description of a handle. This operation can be used to obtain design-time information about running graphs.",
        "summary": "Get a graph description",
        "operationId": "getGraphDescription",
        "produces": [
          "application/json"
        ],
        "responses": {
          "200": {
            "description": "The graph description object.",
            "schema": {
              "$ref": "#/definitions/GraphDescription"
            }
          },
          "500": {
            "description": "An internal server error occurred."
          }
        }
      }
    },
    "/v1/runtime/graphsquery": {
      "post": {
        "tags": [
          "Runtime"
        ],
        "summary": "Query the list of graphs in the runtime",
        "description": "Query the list of graph execution objects using filter, sort, limit, and details clauses. Although issued via an `HTTP POST` request, this operation does not change the existing graph execution objects.",
        "operationId": "queryExecutionGraphs",
        "consumes": [
          "application/json"
        ],
        "produces": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "The query specification object.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/GraphExecutionQuery"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of query result graph execution objects. The response structure depends on the `detailLevel` parameter.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/GraphExecution"
              }
            }
          },
          "400": {
            "description": "Invalid query specification."
          }
        }
      }
    }
  },
  "definitions": {
    "GraphExecutionRequest": {
      "type": "object",
      "properties": {
        "src": {
          "type": "string",
          "description": "Graph source identifier."
        },
        "name": {
          "type": "string",
          "description": "Graph name."
        },
        "executionType": {
          "type": "string",
          "description": "Execution type.",
          "enum": [
            "flow",
            "batch"
          ]
        },
        "configurationSubstitutions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "async": {
          "type": "boolean",
          "description": "If set to `true`, return the graph's handle before its initialization and resource allocation."
        },
        "scheduleTimeoutSeconds": {
          "type": "integer",
          "description": "Timeout for the graph to be scheduled. The default value is \"20m\" in auto-scaling clusters and \"3m\" in non-auto-scalable clusters."
        },
        "autoRestartConfig": {
          "$ref": "#/definitions/AutoRestartConfig"
        },
        "snapshotConfig": {
          "$ref": "#/definitions/SnapshotConfigRequest"
        }
      }
    },
    "GraphExecutionQuery": {
      "type": "object",
      "properties": {
        "detailLevel": {
          "type": "string",
          "description": "Level of detail below which nested objects are removed from query result.",
          "enum": [
            "graph",
            "allocation",
            "process",
            "metric"
          ],
          "example": "graph"
        },
        "filter": {
          "type": "array",
          "description": "A filter expression is a recursively constructed structure that forms an expression tree. All filter expressions are arrays and have the form [ type, (, arguments)+ ].\nThere are logical and predicate expressions.\n* Logical expressions (types: 'and', 'or', 'not') have a list of nested filter expression arguments.\n* Predicate expressions (types: 'equal', 'notEqual', 'greaterThan', 'lessThan', 'greaterOrEqualThan', 'lessOrEqualThan', 'contains', 'startsWith', 'endsWith') always have two arguments.\n* The first argument is a graph execution field specifier.\n* The second argument is a constant value of type corresponding to the predicate type (equal, notEqual: string, integer, bool greaterThan, lessThan, greaterOrEqualThan, lessOrEqualThan: integer; contains, startsWith, endsWith: string)\n",
          "items": {},
          "minItems": 2,
          "example": [
            "or",
            [
              "equal",
              "status",
              "pending"
            ],
            [
              "equal",
              "status",
              "running"
            ]
          ]
        },
        "sortSpecs": {
          "type": "array",
          "description": "Sort specifications determine the order of the result. There can be more than one sort specification, with decreasing priority from left to right. A single sort specification is a two-element array that consists of a GraphExecution field specifier and the sort order ('asc' for ascending or 'desc' for descending).\n",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "example": [
            [
              "updated",
              "desc"
            ]
          ]
        },
        "limit": {
          "type": "integer",
          "description": "The maximum number of graph execution objects in the query result after applying the filter expression.",
          "format": "int64",
          "example": 10
        }
      }
    },
    "GraphExecution": {
      "type": "object",
      "properties": {
        "user": {
          "type": "string",
          "description": "User who started the graph."
        },
        "tenant": {
          "type": "string",
          "description": "Tenant where the graph was started."
        },
        "src": {
          "type": "string",
          "description": "Graph source identifier."
        },
        "name": {
          "type": "string",
          "description": "Graph name."
        },
        "executionType": {
          "type": "string",
          "description": "Execution type.",
          "enum": [
            "stream",
            "batch"
          ]
        },
        "handle": {
          "type": "string",
          "description": "Graph handle."
        },
        "status": {
          "type": "string",
          "description": "Status of the graph execution.",
          "enum": [
            "pending",
            "running",
            "completed",
            "dead",
            "unknown"
          ]
        },
        "terminationRequested": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "description": "Message for further information about the graph execution status."
        },
        "started": {
          "type": "integer",
          "format": "int64",
          "description": "Start time of the graph execution as timestamp."
        },
        "updated": {
          "type": "integer",
          "format": "int64",
          "description": "Last update of the graph execution as timestamp."
        },
        "stopped": {
          "type": "integer",
          "format": "int64",
          "description": "Stop time of the graph execution as timestamp."
        },
        "allocations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GraphAllocation"
          }
        },
        "configurationSubstitutions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "snapshotConfig": {
          "$ref": "#/definitions/SnapshotConfig"
        },
        "autoRestartInfo": {
          "$ref": "#/definitions/AutoRestartInfo"
        }
      }
    },
    "GraphAllocation": {
      "type": "object",
      "properties": {
        "groupName": {
          "type": "string"
        },
        "groupDescription": {
          "type": "string"
        },
        "subgraph": {
          "type": "string"
        },
        "container": {
          "type": "string"
        },
        "containerIp": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "running",
            "completed",
            "dead",
            "unknown"
          ]
        },
        "updated": {
          "type": "integer",
          "format": "int64"
        },
        "message": {
          "type": "string"
        },
        "restartCount": {
          "type": "integer",
          "format": "int32"
        },
        "image": {
          "type": "string"
        },
        "processes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ProcessExecution"
          }
        }
      }
    },
    "SnapshotConfigRequest": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "periodSeconds": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "SnapshotConfig": {
      "type": "object",
      "properties": {
        "recoverWithNewConfigs": {
          "type": "boolean"
        },
        "recoveringHandle": {
          "type": "string"
        },
        "periodSeconds": {
          "type": "integer",
          "format": "int64"
        },
        "usedSpace": {
          "type": "integer",
          "format": "int64"
        },
        "lastSnapshot": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "AutoRestartConfig": {
      "type": "object",
      "properties": {
        "maxRestartCount": {
          "type": "integer"
        },
        "restartDelaySeconds": {
          "type": "integer"
        },
        "resetTimeThreshold": {
          "type": "string",
          "description": "The duration of the running after which a restart is deemed successful and the restart times will be reset to 0 , the minimum value is 30s"
        }
      }
    },
    "AutoRestartInfo": {
      "type": "object",
      "description": "Auto restart configuration information",
      "required": [
        "id",
        "runOrder",
        "runType",
        "maxRestartCount",
        "restartDelaySeconds",
        "resetTimeThreshold",
        "currentFailureCount"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identity of auto restart group"
        },
        "runOrder": {
          "type": "integer",
          "format": "int32",
          "description": "The sequence number of current graph run in the auto restart group"
        },
        "runType": {
          "type": "string",
          "description": "The run type of auto restart group",
          "enum": [
            "normal",
            "autoRestart",
            "manualRestart"
          ]
        },
        "maxRestartCount": {
          "type": "integer",
          "format": "int32",
          "description": "Maximum restart count"
        },
        "restartDelaySeconds": {
          "type": "integer",
          "format": "int32",
          "description": "The duration of the backoff delay before next round restart, unit: seconds"
        },
        "resetTimeThreshold": {
          "type": "string",
          "description": "The duration of the running after which a restart is deemed successful and the restart times will be reset to 0"
        },
        "currentFailureCount": {
          "type": "integer",
          "format": "int32",
          "description": "Restart count in current round"
        }
      }
    },
    "Version": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "Version number."
        },
        "buildTime": {
          "type": "string",
          "format": "date-time",
          "description": "Build time."
        },
        "gitCommit": {
          "type": "string",
          "description": "Git commit ID of the build."
        },
        "platform": {
          "type": "string",
          "description": "Platform of the build.",
          "enum": [
            "darwin",
            "linux",
            "windows"
          ]
        }
      }
    },
    "EntityInfo": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "filename": {
          "type": "string"
        }
      }
    },
    "GraphDescription": {
      "description": "Object representing a modeled graph, i.e. it's representation in the repository.",
      "type": "object",
      "properties": {
        "variables": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "processes": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/ProcessDescription"
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GroupDescription"
          }
        },
        "connections": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Connection"
          }
        },
        "inports": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Port"
          }
